version: "3.9"

services:

  # =========================
  # POSTGRES SP
  # =========================
  postgres_sp:
    image: postgres:15
    container_name: postgres_sp
    restart: always
    environment:
      POSTGRES_DB: locker_sp
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: admin123
    ports:
      - "5433:5432"
    volumes:
      - ../03_data/postgres_sp:/var/lib/postgresql/data

  # =========================
  # POSTGRES PT
  # =========================
  postgres_pt:
    image: postgres:15
    container_name: postgres_pt
    restart: always
    environment:
      POSTGRES_DB: locker_pt
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: admin123
    ports:
      - "5434:5432"
    volumes:
      - ../03_data/postgres_pt:/var/lib/postgresql/data

  # =========================
  # REDIS SP
  # =========================
  redis_sp:
    image: redis:7
    container_name: redis_sp
    restart: always
    ports:
      - "6380:6379"
    volumes:
      - ../03_data/redis_sp:/data

  # =========================
  # REDIS PT
  # =========================
  redis_pt:
    image: redis:7
    container_name: redis_pt
    restart: always
    ports:
      - "6381:6379"
    volumes:
      - ../03_data/redis_pt:/data

  # =========================
  # MQTT BROKER
  # =========================
  mqtt:
    image: eclipse-mosquitto:2
    container_name: mqtt_broker
    restart: always
    ports:
      - "1884:1883"
    volumes:
      - ../03_data/mqtt:/mosquitto/data
  
  # =========================
  # BACKEND SP
  # =========================
  backend_sp:
    build:
      context: ../01_source/backend_sp
    container_name: backend_sp
    restart: always
    ports:
      - "8001:8000"
    environment:
      DB_HOST: postgres_sp
      DB_NAME: locker_sp
      DB_USER: admin
      DB_PASS: admin123
    depends_on:
      - postgres_sp
      - redis_sp
